# Turkish Agent Tutor — Environment Variables
# Copy to .env and fill in before running.

# Required: get a free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Web app / API origins
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_API_URL=http://127.0.0.1:8000

# Persistent saved lessons and auth
# Local default if omitted: sqlite:///data/turkish_tutor.sqlite3
# Render Postgres example: postgresql://user:password@host:5432/database
DATABASE_URL=sqlite:///data/turkish_tutor.sqlite3
AUTH_SESSION_DAYS=30
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAMESITE=lax

# Password reset
# Without an email provider, reset tokens are created but not emailed.
# Set PASSWORD_RESET_RETURN_TOKEN=true only for local development/testing.
PASSWORD_RESET_MINUTES=30
PASSWORD_RESET_RETURN_TOKEN=false
PASSWORD_RESET_BASE_URL=http://localhost:3000
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_USE_TLS=true

# OAuth. Password auth works without these.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/oauth/google/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/oauth/github/callback
OAUTH_SUCCESS_REDIRECT_URL=http://localhost:3000/?oauth=success
OAUTH_ERROR_REDIRECT_URL=http://localhost:3000/?oauth=error
OAUTH_STATE_MINUTES=10
OAUTH_HANDOFF_MINUTES=5

# In-process rate limiting. Use Redis/shared limiting if you run multiple API instances.
RATE_LIMIT_ENABLED=true
RATE_LIMIT_SIGNUP=5/1h
RATE_LIMIT_LOGIN=10/5m
RATE_LIMIT_PASSWORD_RESET=5/1h
RATE_LIMIT_PASSWORD_RESET_CONFIRM=10/1h
RATE_LIMIT_STUDY=30/1h
RATE_LIMIT_LESSON_WRITE=120/1h
